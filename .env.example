# Public URL used for canonical metadata and links.
NEXT_PUBLIC_SITE_URL=https://example.com
SITE_URL=https://example.com

# Supabase Postgres. Both values are server-only; never add NEXT_PUBLIC_.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SECRET_KEY=sb_secret_replace_with_a_server_only_key

# Resend. Use a verified domain in production so confirmations can reach clients.
RESEND_API_KEY=re_replace_with_a_rotated_key
RESEND_FROM_EMAIL=Voicyy <richieste@example.com>
ADMIN_NOTIFICATION_EMAIL=info.voicyy@gmail.com

# Admin authentication. Never put plaintext credentials in source control.
# In local .env files, escape each bcrypt "$" as "\$"; Vercel accepts it raw.
ADMIN_PASSWORD_HASH=$2b$12$replace_with_a_bcrypt_hash
# bcrypt(SHA-256 base64url della frase normalizzata: minuscole e singoli spazi)
ADMIN_RECOVERY_PHRASE_HASH=$2b$12$bcrypt_of_sha256_base64url_digest
ADMIN_SESSION_SECRET=
ADMIN_ENCRYPTION_KEY=replace_with_32_random_bytes_as_base64url_or_64_hex
ADMIN_TOTP_LABEL=Voicyy Admin
REQUEST_FINGERPRINT_SECRET=
CRON_SECRET=

# Optional Google Drive export. Leave disabled until a dedicated service account
# exists and the destination folder has been shared with that account.
GOOGLE_DRIVE_FOLDER_ID=1W9a0hzTXSKr0YS10OV-lNFB2-1rkR6ql
GOOGLE_SERVICE_ACCOUNT_JSON=
