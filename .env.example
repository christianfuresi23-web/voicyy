# Public URL used for canonical metadata and links.
NEXT_PUBLIC_SITE_URL=https://example.com
SITE_URL=https://example.com

# Supabase write-only ingress. Server-only: never add NEXT_PUBLIC_. Use the
# publishable key, never service_role/secret/DATABASE_URL on Vercel.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_replace_me
# Generate 48 random bytes (64 base64 characters). Store the clear text only in
# Vercel and solely its SHA-256 digest in private.request_ingress_secret.
SUBMISSION_WRITE_SECRET=
# Generate 32 random bytes in base64. This encrypts every request with
# AES-256-GCM before it leaves Vercel. Never store it in Supabase.
REQUEST_DATA_ENCRYPTION_KEY=

# Resend. Use a verified domain in production so confirmations can reach clients.
RESEND_API_KEY=re_replace_with_a_rotated_key
RESEND_FROM_EMAIL=Voicyy <richieste@example.com>
ADMIN_NOTIFICATION_EMAIL=info.voicyy@gmail.com

# Copiare queste tre righe in .env.viewer.local solo sul PC autorizzato.
# Non aggiungerle a .env.local del sito e non configurarle su Vercel.
# Usa un LOGIN PostgreSQL dedicato, membro di voicyy_local_reader, con password
# diversa da ogni altra credenziale e default_transaction_read_only=on.
LOCAL_DATABASE_URL=postgresql://voicyy_local_viewer:replace_with_a_long_random_password@your-database-host:5432/postgres?sslmode=verify-full
# Stesso valore di REQUEST_DATA_ENCRYPTION_KEY, conservato solo su questo PC.
LOCAL_DATA_ENCRYPTION_KEY=
LOCAL_VIEWER_PORT=4317

# Optional Google Drive export. Leave disabled until a dedicated service account
# exists and the destination folder has been shared with that account.
GOOGLE_DRIVE_FOLDER_ID=1W9a0hzTXSKr0YS10OV-lNFB2-1rkR6ql
GOOGLE_SERVICE_ACCOUNT_JSON=
